# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_database_password
DB_DATABASE=todo_db

# 邮箱配置
MAIL_HOST=smtp.163.com
MAIL_PORT=465
MAIL_USER=your_email@163.com
MAIL_PASSWORD=your_email_password_or_auth_code
MAIL_FROM=your_email@163.com

# 服务器配置
PORT=3000
# CORS配置（多个来源用逗号分隔）
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173


# 阿里云OSS配置
OSS_REGION=oss-cn-beijing
OSS_BUCKET=todo-avatar
OSS_ENDPOINT=https://oss-cn-beijing.aliyuncs.com
OSS_USE_STS=true
OSS_ACCESS_KEY_ID=your_aliyun_access_key_id
OSS_ACCESS_KEY_SECRET=your_aliyun_access_key_secret
OSS_STS_ROLE_ARN=acs:ram::1234567890123456:role/your-sts-role
